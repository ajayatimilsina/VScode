<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Japanese い</i> Practice App</title>

<style>

body{
    margin:0;
    background:#111827;
    font-family:system-ui;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

/* BOARD */
.board{
    position:relative;
    width:90%;
    max-width:900px;
    aspect-ratio:16/9;
    background:white;
    border-radius:16px;
    overflow:hidden;
    border:4px solid #f59e0b;
}

/* BIG CENTER CHARACTER */
.center{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    font-size:10rem;
    color:#f43f5e;
    opacity:0.15;
    font-weight:bold;
    pointer-events:none;
}

/* CANVAS */
canvas{
    position:absolute;
    inset:0;
    width:100%;
    height:100%;
    cursor:crosshair;
}

/* CONTROL */
.controls{
    margin-top:15px;
    display:flex;
    justify-content:space-between;
    background:#1f2937;
    padding:15px;
    border-radius:12px;
}

/* BUTTONS */
button{
    padding:10px 18px;
    border:none;
    border-radius:8px;
    font-weight:bold;
    cursor:pointer;
}

.clear{background:#ef4444;color:white;}
.demo{background:#f59e0b;color:black;}

/* TIMER */
#timer{
    color:#f59e0b;
    font-family:monospace;
}

</style>

</head>

<body>

<div>

<h2 style="text-align:center;margin-bottom:10px;">
Japanese い Writing App
</h2>

<div class="board">

```
<div class="center">い</div>

<canvas id="canvas"></canvas>
```

</div>

<div class="controls">

```
<button class="clear" id="clearBtn">Clear</button>

<div id="timer">Drawing Mode</div>

<button class="demo" id="demoBtn">Demo</button>
```

</div>

</div>

<script>

const canvas=document.getElementById("canvas");
const ctx=canvas.getContext("2d");

let drawing=false;

/* resize */
function resize(){
    canvas.width=canvas.offsetWidth;
    canvas.height=canvas.offsetHeight;

    ctx.lineWidth=5;
    ctx.lineCap="round";
}
resize();
window.addEventListener("resize",resize);

/* position */
function pos(e){
    const r=canvas.getBoundingClientRect();

    if(e.touches){
        return {
            x:e.touches[0].clientX-r.left,
            y:e.touches[0].clientY-r.top
        };
    }

    return {
        x:e.clientX-r.left,
        y:e.clientY-r.top
    };
}

/* DRAW START */
canvas.addEventListener("mousedown",(e)=>{
    drawing=true;
    const p=pos(e);
    ctx.beginPath();
    ctx.moveTo(p.x,p.y);
});

/* DRAW MOVE */
canvas.addEventListener("mousemove",(e)=>{
    if(!drawing) return;
    const p=pos(e);
    ctx.lineTo(p.x,p.y);
    ctx.stroke();
});

/* STOP */
canvas.addEventListener("mouseup",()=>drawing=false);
canvas.addEventListener("mouseleave",()=>drawing=false);

/* TOUCH */
canvas.addEventListener("touchstart",(e)=>{
    drawing=true;
    const p=pos(e);
    ctx.beginPath();
    ctx.moveTo(p.x,p.y);
});

canvas.addEventListener("touchmove",(e)=>{
    const p=pos(e);
    ctx.lineTo(p.x,p.y);
    ctx.stroke();
});

canvas.addEventListener("touchend",()=>drawing=false);

/* CLEAR */
document.getElementById("clearBtn").onclick=()=>{
    ctx.clearRect(0,0,canvas.width,canvas.height);
};

/* DEMO DRAW */
document.getElementById("demoBtn").onclick=()=>{
    ctx.clearRect(0,0,canvas.width,canvas.height);

    let pts=[
        [200,150],[300,140],[400,130],
        [350,220],[330,320],[290,400],
        [250,300],[220,380],[260,450]
    ];

    let i=0;

    function draw(){
        if(i>=pts.length-1) return;

        ctx.beginPath();
        ctx.moveTo(pts[i][0],pts[i][1]);
        ctx.lineTo(pts[i+1][0],pts[i+1][1]);
        ctx.stroke();

        i++;
        setTimeout(draw,100);
    }

    draw();
};

</script>

</body>
</html>
