<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Japanese い Practice App</title>
<style>
body {
    margin: 0;
    background: #111827;
    font-family: system-ui;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

/* BOARD */
.board {
    position: relative;
    width: 90%;
    max-width: 900px;
    aspect-ratio: 16/9;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    border: 4px solid #f59e0b;
}

/* INAKA BACKGROUND PICTURE */
.inaka-bg {
    position: absolute;
    inset: 0;
    /* フリーの田舎の風景画像を使用しています */
    background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1000&q=80');
    background-size: cover;
    background-position: center;
    transition: opacity 1s ease-in-out;
    zIndex: 5;
    pointer-events: none; /* 画像表示中はクリックを透過 */
}

/* BIG CENTER CHARACTER */
.center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 10rem;
    color: #f43f5e;
    opacity: 0; /* 最初は非表示 */
    font-weight: bold;
    pointer-events: none;
    transition: opacity 1s ease-in-out;
}

/* CANVAS */
canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    cursor: crosshair;
    opacity: 0; /* 最初は描画不可 */
    pointer-events: none;
    transition: opacity 1s ease-in-out;
}

/* CONTROL */
.controls {
    margin-top: 15px;
    display: flex;
    justify-content: space-between;
    background: #1f2937;
    padding: 15px;
    border-radius: 12px;
}

/* BUTTONS */
button {
    padding: 10px 18px;
    border: none;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}
button:disabled {
    background: #4b5563;
    color: #9ca3af;
    cursor: not-allowed;
}

.clear { background: #ef4444; color: white; }
.demo { background: #f59e0b; color: black; }

/* TIMER */
#timer {
    color: #f59e0b;
    font-family: monospace;
    font-size: 1.2rem;
    align-self: center;
}
</style>
</head>
<body>

<div>
<h2 id="app-title" style="text-align:center;margin-bottom:10px;">
    Look at the Countryside (いなか - Inaka)
</h2>

<div class="board">
    <!-- 田舎の画像レイヤー -->
    <div class="inaka-bg" id="inakaBg"></div>
    <!-- 「い」の文字レイヤー -->
    <div class="center" id="centerChar">い</div>
    <canvas id="canvas"></canvas>
</div>

<div class="controls">
    <button class="clear" id="clearBtn" disabled>Clear</button>
    <div id="timer">Time Left: 20s</div>
    <button class="demo" id="demoBtn" disabled>Demo</button>
</div>
</div>

<script>
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");
const timerEl = document.getElementById("timer");
const inakaBg = document.getElementById("inakaBg");
const centerChar = document.getElementById("centerChar");
const appTitle = document.getElementById("app-title");
const clearBtn = document.getElementById("clearBtn");
const demoBtn = document.getElementById("demoBtn");

let drawing = false;
let appMode = "look"; // "look" もしくは "write"

/* resize */
function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
    ctx.lineWidth = 10; // 線を少し太くして書きやすくしました
    ctx.lineCap = "round";
    ctx.strokeStyle = "#10b981"; // 緑色のペン
}
resize();
window.addEventListener("resize", resize);

/* 20秒のカウントダウンタイマー */
let timeLeft = 20;
const countdown = setInterval(() => {
    timeLeft--;
    if (timeLeft > 0) {
        timerEl.innerText = `Time Left: ${timeLeft}s`;
    } else {
        clearInterval(countdown);
        startWritingMode(); // 20秒後に切り替え
    }
}, 1000);

/* モード切り替え関数 */
function startWritingMode() {
    appMode = "write";
    
    // タイトルとタイマーの更新
    appTitle.innerText = "Japanese い Writing App";
    timerEl.innerText = "Drawing Mode";
    
    // アニメーションで画面を切り替え
    inakaBg.style.opacity = "0";
    centerChar.style.opacity = "0.15";
    canvas.style.opacity = "1";
    
    // ボタンとキャンバスを使えるようにする
    canvas.style.pointerEvents = "auto";
    clearBtn.disabled = false;
    demoBtn.disabled = false;
}

/* position */
function pos(e) {
    const r = canvas.getBoundingClientRect();
    if (e.touches && e.touches.length > 0) {
        return {
            x: e.touches[0].clientX - r.left,
            y: e.touches[0].clientY - r.top
        };
    }
    return {
        x: e.clientX - r.left,
        y: e.clientY - r.top
    };
}

/* DRAW START */
canvas.addEventListener("mousedown", (e) => {
    if (appMode !== "write") return;
    drawing = true;
    const p = pos(e);
    ctx.beginPath();
    ctx.moveTo(p.x, p.y);
});

/* DRAW MOVE */
canvas.addEventListener("mousemove", (e) => {
    if (!drawing || appMode !== "write") return;
    const p = pos(e);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
});

/* STOP */
canvas.addEventListener("mouseup", () => drawing = false);
canvas.addEventListener("mouseleave", () => drawing = false);

/* TOUCH (スマホ対応) */
canvas.addEventListener("touchstart", (e) => {
    if (appMode !== "write") return;
    drawing = true;
    const p = pos(e);
    ctx.beginPath();
    ctx.moveTo(p.x, p.y);
});

canvas.addEventListener("touchmove", (e) => {
    if (!drawing || appMode !== "write") return;
    const p = pos(e);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
});

canvas.addEventListener("touchend", () => drawing = false);

/* CLEAR */
clearBtn.onclick = () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
};

/* DEMO DRAW */
demoBtn.onclick = () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // 「い」の形に合わせた綺麗なデモ座標
    let stroke1 = [[250, 150], [240, 250], [260, 350], [300, 320]];
    let stroke2 = [[450, 180], [470, 260], [440, 320]];

    function drawStroke(points, index, callback) {
        if (index >= points.length - 1) {
            if (callback) callback();
            return;
        }
        ctx.beginPath();
        ctx.moveTo(points[index][0], points[index][1]);
        ctx.lineTo(points[index+1][0], points[index+1][1]);
        ctx.stroke();
        setTimeout(() => drawStroke(points, index + 1, callback), 80);
    }

    // 1画目を描いてから2画目を描く
    drawStroke(stroke1, 0, () => {
        setTimeout(() => {
            drawStroke(stroke2, 0);
        }, 200);
    });
};
</script>
</body>
</html>
